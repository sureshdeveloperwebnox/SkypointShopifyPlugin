<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>SkyTrack</title>
    <base href="/" />
    <link rel="stylesheet" href="css/bootstrap/bootstrap.min.css" />
    <link rel="stylesheet" href="css/site.css" />
    <link rel="stylesheet" href="css/auth.css" />
    <link rel="stylesheet" href="SkypointShopifyPlugin.WebUI.styles.css" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/5.15.4/css/all.min.css" />
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;600;700;800;900&family=Inter:wght@300;400;600;700;800&display=swap" rel="stylesheet">
    <ImportMap />
    <link rel="icon" type="image/png" href="favicon.png" />
    <HeadOutlet @rendermode="InteractiveServer" />
</head>

<body>
    <Routes @rendermode="InteractiveServer" />
    <script src="_framework/blazor.web.js"></script>
    <script>
        window.skypointPudo = {
            popupWindow: null,
            dotNetHelper: null,
            guid: null,
            
            openPudoSelector: function (guid, widgetUrl, dotNetHelper) {
                window.skypointPudo.dotNetHelper = dotNetHelper;
                window.skypointPudo.guid = guid;
                
                console.log('Opening SkyPoint Selector URL:', widgetUrl);
                
                const width = 800;
                const height = 650;
                const left = (screen.width - width) / 2;
                const top = (screen.height - height) / 2;
                
                window.skypointPudo.popupWindow = window.open(
                    widgetUrl, 
                    'SkyPointPudoSelector', 
                    `width=${width},height=${height},left=${left},top=${top},resizable=yes,scrollbars=yes,status=yes`
                );
                
                if (window.skypointPudo.popupWindow) {
                    window.skypointPudo.popupWindow.focus();
                } else {
                    alert('Popup blocked! Please allow popups for this site to select a PUDO counter.');
                }
            },
            
            closePopup: function () {
                if (window.skypointPudo.popupWindow) {
                    window.skypointPudo.popupWindow.close();
                    window.skypointPudo.popupWindow = null;
                }
            },
            
            receiveSkyPointMessage: function (event) {
                console.log('Message received from SkyPoint:', event.data);
                
                let data = event.data;
                if (typeof data === 'string') {
                    try {
                        data = JSON.parse(data);
                    } catch (e) {
                        // Ignore non-JSON strings
                    }
                }
                
                if (data && data.result === 'success') {
                    console.log('SkyPoint selection success! GUID:', window.skypointPudo.guid);
                    window.skypointPudo.closePopup();
                    
                    if (window.skypointPudo.dotNetHelper) {
                        window.skypointPudo.dotNetHelper.invokeMethodAsync('OnPudoSelected', window.skypointPudo.guid);
                    }
                }
            }
        };
        
        // Register listener globally on startup to prevent timing/re-registration issues
        window.addEventListener('message', window.skypointPudo.receiveSkyPointMessage);
    </script>
</body>

</html>
