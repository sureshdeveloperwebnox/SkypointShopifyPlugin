@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

<div class="auth-layout">
    <!-- Top Navbar -->
    <nav class="navbar auth-navbar">
        <div class="navbar-container">
            <a class="navbar-brand" href="/">
                <img src="images/skynet_logo.jpeg" alt="SkyNet Logo" style="height: 40px; vertical-align: middle; border-radius: 4px;" />
            </a>
            <div class="navbar-links">
                <a href="@GetLink("/register")" class="nav-link-btn @(IsActive("/register") ? "active" : "")">Register</a>
                <a href="@GetLink("/login")" class="nav-link-btn @(IsActive("/login") ? "active" : "")">Login</a>
            </div>
        </div>
    </nav>

    <!-- Page Content -->
    <div class="auth-content">
        @Body
    </div>
</div>

@code {
    private bool IsActive(string path)
    {
        var uri = new Uri(NavigationManager.Uri);
        return uri.AbsolutePath.Equals(path, StringComparison.OrdinalIgnoreCase);
    }

    private string GetLink(string path)
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = uri.Query;
        return string.IsNullOrEmpty(query) ? path : $"{path}{query}";
    }
}
