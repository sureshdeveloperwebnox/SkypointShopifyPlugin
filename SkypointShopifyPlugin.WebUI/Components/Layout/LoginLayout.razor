@inherits LayoutComponentBase
@inject NavigationManager NavigationManager

<div class="auth-layout">
    <!-- Top Navbar -->
    <nav class="navbar auth-navbar">
        <div class="navbar-container">
            <a class="navbar-brand" href="/">
                <svg viewBox="0 0 220 50" width="180" height="40" style="vertical-align: middle;">
                    <defs>
                        <linearGradient id="skynet-red" x1="0%" y1="0%" x2="100%" y2="0%">
                            <stop offset="0%" stop-color="#ff1e27" />
                            <stop offset="100%" stop-color="#d30008" />
                        </linearGradient>
                    </defs>
                    <text x="5" y="32" font-family="'Impact', 'Arial Black', sans-serif" font-weight="900" font-style="italic" font-size="30" fill="url(#skynet-red)" letter-spacing="-1">SKYNET</text>
                    <text x="7" y="44" font-family="'Arial', sans-serif" font-weight="800" font-size="7.5" fill="#111111" letter-spacing="2.2">WORLDWIDE EXPRESS</text>
                    <path d="M 5 35 L 122 35" stroke="#ff1e27" stroke-width="1.5" />
                </svg>
            </a>
            <div class="navbar-links">
                <a href="@GetLink("/register")" class="nav-link-btn @(IsActive("/register") ? "active" : "")">Register</a>
                <a href="@GetLink("/login")" class="nav-link-btn @(IsActive("/login") ? "active" : "")">Login</a>
            </div>
        </div>
    </nav>

    <!-- Page Content -->
    <div class="auth-content">
        @Body
    </div>
</div>

@code {
    private bool IsActive(string path)
    {
        var uri = new Uri(NavigationManager.Uri);
        return uri.AbsolutePath.Equals(path, StringComparison.OrdinalIgnoreCase);
    }

    private string GetLink(string path)
    {
        var uri = new Uri(NavigationManager.Uri);
        var query = uri.Query;
        return string.IsNullOrEmpty(query) ? path : $"{path}{query}";
    }
}
