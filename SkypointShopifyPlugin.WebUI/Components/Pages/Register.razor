@page "/register"
@layout LoginLayout
@inject HttpClient Http
@inject NavigationManager NavigationManager

<div class="auth-card" style="max-width: 550px;">
    <div class="text-center mb-4">
        <h4 class="auth-card-title">Register as a SkyNet Client</h4>
        <p class="auth-card-subtitle">Complete the fields below to create your account</p>
    </div>

    <EditForm Model="@regModel" OnValidSubmit="HandleRegistration">
        <DataAnnotationsValidator />
        
        <div class="row">
            <div class="col-md-6 form-group-custom">
                <label class="form-label-custom" for="firstName">First Name</label>
                <div class="input-container">
                    <InputText id="firstName" class="form-input-custom" placeholder="John" @bind-Value="regModel.FirstName" required />
                </div>
                <ValidationMessage For="@(() => regModel.FirstName)" style="color: #f87171; font-size: 0.8rem; margin-top: 5px;" />
            </div>

            <div class="col-md-6 form-group-custom">
                <label class="form-label-custom" for="lastName">Last Name</label>
                <div class="input-container">
                    <InputText id="lastName" class="form-input-custom" placeholder="Doe" @bind-Value="regModel.LastName" required />
                </div>
                <ValidationMessage For="@(() => regModel.LastName)" style="color: #f87171; font-size: 0.8rem; margin-top: 5px;" />
            </div>
        </div>

        <div class="form-group-custom">
            <label class="form-label-custom" for="email">Email Address</label>
            <div class="input-container">
                <InputText id="email" type="email" class="form-input-custom" placeholder="john.doe@example.com" @bind-Value="regModel.Email" required />
            </div>
            <ValidationMessage For="@(() => regModel.Email)" style="color: #f87171; font-size: 0.8rem; margin-top: 5px;" />
        </div>

        <div class="form-group-custom">
            <label class="form-label-custom" for="phone">Mobile Number</label>
            <div class="input-container">
                <InputText id="phone" type="tel" class="form-input-custom" placeholder="+27 82 123 4567" @bind-Value="regModel.Phone" required />
            </div>
            <ValidationMessage For="@(() => regModel.Phone)" style="color: #f87171; font-size: 0.8rem; margin-top: 5px;" />
        </div>

        <div class="form-group-custom">
            <label class="form-label-custom" for="accountNumber">SkyNet Account Number</label>
            <div class="input-container">
                <InputText id="accountNumber" class="form-input-custom" placeholder="J12345 (Optional)" @bind-Value="regModel.AccountNumber" />
            </div>
        </div>

        <div class="row">
            <div class="col-md-6 form-group-custom">
                <label class="form-label-custom" for="password">Password</label>
                <div class="input-container">
                    <input type="@PasswordType" id="password" class="form-input-custom" placeholder="••••••••" @bind="regModel.Password" minlength="6" required />
                    <i class="@PasswordToggleIcon password-toggle-icon" @onclick="TogglePasswordVisibility"></i>
                </div>
                <ValidationMessage For="@(() => regModel.Password)" style="color: #f87171; font-size: 0.8rem; margin-top: 5px;" />
            </div>

            <div class="col-md-6 form-group-custom">
                <label class="form-label-custom" for="confirmPassword">Confirm Password</label>
                <div class="input-container">
                    <input type="@PasswordType" id="confirmPassword" class="form-input-custom" placeholder="••••••••" @bind="regModel.ConfirmPassword" required />
                </div>
                <ValidationMessage For="@(() => regModel.ConfirmPassword)" style="color: #f87171; font-size: 0.8rem; margin-top: 5px;" />
            </div>
        </div>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="msg error" style="display: block;">@errorMessage</div>
        }
        @if (!string.IsNullOrEmpty(successMessage))
        {
            <div class="msg success" style="display: block;">@successMessage</div>
        }

        <div class="mt-4">
            <button type="submit" class="btn-skynet-primary" disabled="@isSubmitting">
                @(isSubmitting ? "Creating Account..." : "Create Account")
            </button>
            <a role="button" class="btn-skynet-secondary text-center d-block mt-2" href="@GetLoginUrl()">Back to Login</a>
        </div>
    </EditForm>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Shop { get; set; }

    private RegisterViewModel regModel = new();
    private bool isSubmitting = false;
    private bool showPassword = false;
    private string? errorMessage;
    private string? successMessage;

    private string PasswordType => showPassword ? "text" : "password";
    private string PasswordToggleIcon => showPassword ? "fas fa-eye-slash" : "fas fa-eye";

    private void TogglePasswordVisibility()
    {
        showPassword = !showPassword;
    }

    private string GetLoginUrl()
    {
        return string.IsNullOrEmpty(Shop) ? "/login" : $"/login?shop={Uri.EscapeDataString(Shop)}";
    }

    private async Task HandleRegistration()
    {
        errorMessage = null;
        successMessage = null;

        if (regModel.Password != regModel.ConfirmPassword)
        {
            errorMessage = "Passwords do not match";
            return;
        }

        isSubmitting = true;
        StateHasChanged();

        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/register", new {
                email = regModel.Email,
                firstName = regModel.FirstName,
                lastName = regModel.LastName,
                phone = regModel.Phone,
                password = regModel.Password
            });

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<RegisterResult>();
                if (result != null && result.Success)
                {
                    successMessage = "Registration successful! Redirecting to login...";
                    StateHasChanged();
                    await Task.Delay(2000);
                    NavigationManager.NavigateTo(GetLoginUrl());
                    return;
                }
            }

            var errData = await response.Content.ReadFromJsonAsync<ErrorResponse>();
            errorMessage = errData?.Error ?? "Registration failed";
        }
        catch (Exception ex)
        {
            errorMessage = $"Network error: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    public class RegisterViewModel
    {
        [Required(ErrorMessage = "First name is required")]
        public string FirstName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Last name is required")]
        public string LastName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email address is required")]
        [EmailAddress(ErrorMessage = "Please enter a valid email address")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Mobile number is required")]
        public string Phone { get; set; } = string.Empty;

        public string? AccountNumber { get; set; }

        [Required(ErrorMessage = "Password is required")]
        [MinLength(6, ErrorMessage = "Password must be at least 6 characters")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "Confirm password is required")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }

    public class RegisterResult
    {
        public bool Success { get; set; }
        public string? Token { get; set; }
    }

    public class ErrorResponse
    {
        public string? Error { get; set; }
    }
}
