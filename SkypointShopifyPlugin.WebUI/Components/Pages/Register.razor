@page "/register"
@layout LoginLayout
@inject HttpClient Http
@inject NavigationManager NavigationManager
@using System.ComponentModel.DataAnnotations

<div class="split-layout-container">
    <!-- Left Feature Pane -->
    <div class="split-left-pane">
        <div class="left-pane-pill">
            <i class="fas fa-user-plus mr-2"></i> New Customer
        </div>
        <h1 class="left-pane-title">
            Join SkyNet Online<br />
            in minutes
        </h1>
        <p class="left-pane-desc">
            Create your free account and start sending packages locally and internationally — no paperwork, no hassle.
        </p>

        <div class="left-pane-features">
            <div class="feature-item">
                <div class="feature-icon-wrapper" style="font-weight: 800; font-size: 0.95rem;">
                    1
                </div>
                <div>
                    <div class="feature-text-title">Create your account</div>
                    <div class="feature-text-desc">Fill in your personal details and set a secure password.</div>
                </div>
            </div>

            <div class="feature-item">
                <div class="feature-icon-wrapper" style="font-weight: 800; font-size: 0.95rem;">
                    2
                </div>
                <div>
                    <div class="feature-text-title">Top up your wallet</div>
                    <div class="feature-text-desc">Add funds via card, EFT, or any supported payment method.</div>
                </div>
            </div>

            <div class="feature-item">
                <div class="feature-icon-wrapper" style="font-weight: 800; font-size: 0.95rem;">
                    3
                </div>
                <div>
                    <div class="feature-text-title">Ship your first parcel</div>
                    <div class="feature-text-desc">Create a waybill, print your label, and drop off your package.</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Form Pane -->
    <div class="split-right-pane">
        <div class="form-card-wrapper" style="max-width: 540px;">
            <div class="form-pill-badge">
                Customer Registration
            </div>
            <h2 class="form-welcome-title">Create your account</h2>
            <p class="form-welcome-subtitle">All fields are required unless marked optional.</p>

            <EditForm Model="@regModel" OnValidSubmit="HandleRegistration">
                <DataAnnotationsValidator />

                <div style="font-size: 0.85rem; font-weight: 700; color: #64748b; text-transform: uppercase; letter-spacing: 0.5px; margin-bottom: 1rem;">
                    Personal Details
                </div>

                <div style="display: flex; gap: 1rem; width: 100%;">
                    <div class="form-group-light" style="flex: 1;">
                        <label class="form-label-light" for="firstName">First Name</label>
                        <div class="input-container-light">
                            <i class="fas fa-user input-icon-left"></i>
                            <InputText id="firstName" class="form-input-light" placeholder="Name" @bind-Value="regModel.FirstName" required />
                        </div>
                        <ValidationMessage For="@(() => regModel.FirstName)" style="color: #ef4444; font-size: 0.8rem; margin-top: 5px;" />
                    </div>

                    <div class="form-group-light" style="flex: 1;">
                        <label class="form-label-light" for="lastName">Surname</label>
                        <div class="input-container-light">
                            <i class="fas fa-user input-icon-left"></i>
                            <InputText id="lastName" class="form-input-light" placeholder="Surname" @bind-Value="regModel.LastName" required />
                        </div>
                        <ValidationMessage For="@(() => regModel.LastName)" style="color: #ef4444; font-size: 0.8rem; margin-top: 5px;" />
                    </div>
                </div>

                <div class="form-group-light">
                    <label class="form-label-light" for="phone">Mobile Number</label>
                    <div class="input-container-light">
                        <i class="fas fa-phone input-icon-left"></i>
                        <InputText id="phone" type="tel" class="form-input-light" placeholder="Mobile number" @bind-Value="regModel.Phone" required />
                    </div>
                    <ValidationMessage For="@(() => regModel.Phone)" style="color: #ef4444; font-size: 0.8rem; margin-top: 5px;" />
                </div>

                <div class="form-group-light">
                    <label class="form-label-light" for="email">Email Address</label>
                    <div class="input-container-light">
                        <i class="fas fa-envelope input-icon-left"></i>
                        <InputText id="email" type="email" class="form-input-light" placeholder="Email" @bind-Value="regModel.Email" required />
                    </div>
                    <ValidationMessage For="@(() => regModel.Email)" style="color: #ef4444; font-size: 0.8rem; margin-top: 5px;" />
                </div>

                <div class="form-group-light">
                    <label class="form-label-light" for="accountNumber">Sales Code <span style="text-transform: lowercase; font-weight: normal; color: #94a3b8;">(optional)</span></label>
                    <div class="input-container-light">
                        <i class="fas fa-tag input-icon-left"></i>
                        <InputText id="accountNumber" class="form-input-light" placeholder="Sales code (Optional)" @bind-Value="regModel.AccountNumber" />
                    </div>
                </div>

                <div style="display: flex; gap: 1rem; width: 100%;">
                    <div class="form-group-light" style="flex: 1;">
                        <label class="form-label-light" for="password">Password</label>
                        <div class="input-container-light">
                            <i class="fas fa-lock input-icon-left"></i>
                            <input type="@PasswordType" id="password" class="form-input-light" placeholder="Password" @bind="regModel.Password" minlength="6" required />
                            <i class="@PasswordToggleIcon password-toggle-light" @onclick="TogglePasswordVisibility"></i>
                        </div>
                        <ValidationMessage For="@(() => regModel.Password)" style="color: #ef4444; font-size: 0.8rem; margin-top: 5px;" />
                    </div>

                    <div class="form-group-light" style="flex: 1;">
                        <label class="form-label-light" for="confirmPassword">Confirm Password</label>
                        <div class="input-container-light">
                            <i class="fas fa-lock input-icon-left"></i>
                            <input type="@PasswordType" id="confirmPassword" class="form-input-light" placeholder="Confirm password" @bind="regModel.ConfirmPassword" required />
                        </div>
                        <ValidationMessage For="@(() => regModel.ConfirmPassword)" style="color: #ef4444; font-size: 0.8rem; margin-top: 5px;" />
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="msg error" style="display: block; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: #ef4444; padding: 10px 15px; border-radius: 6px; margin-bottom: 1.5rem; font-size: 0.9rem;">@errorMessage</div>
                }
                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div class="msg success" style="display: block; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2); color: #10b981; padding: 10px 15px; border-radius: 6px; margin-bottom: 1.5rem; font-size: 0.9rem;">@successMessage</div>
                }

                <button type="submit" class="btn-skynet-red" disabled="@isSubmitting">
                    <i class="fas fa-user-check mr-2"></i> @(isSubmitting ? "Creating Account..." : "Create my account")
                </button>

                <div style="text-align: center; margin-top: 2rem; font-size: 0.9rem; color: #64748b;">
                    Already have an account? <a href="@GetLoginUrl()" class="form-link-highlight">Sign in here &rarr;</a>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Shop { get; set; }

    private RegisterViewModel regModel = new();
    private bool isSubmitting = false;
    private bool showPassword = false;
    private string? errorMessage;
    private string? successMessage;

    private string PasswordType => showPassword ? "text" : "password";
    private string PasswordToggleIcon => showPassword ? "fas fa-eye-slash" : "fas fa-eye";

    private void TogglePasswordVisibility()
    {
        showPassword = !showPassword;
    }

    private string GetLoginUrl()
    {
        return string.IsNullOrEmpty(Shop) ? "/login" : $"/login?shop={Uri.EscapeDataString(Shop)}";
    }

    private void LoginAsGuest()
    {
        errorMessage = "Guest checkout is active by default at store frontends. Please register or sign in to configure your backend integrations.";
    }

    private async Task HandleRegistration()
    {
        errorMessage = null;
        successMessage = null;

        if (regModel.Password != regModel.ConfirmPassword)
        {
            errorMessage = "Passwords do not match";
            return;
        }

        isSubmitting = true;
        StateHasChanged();

        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/register", new {
                email = regModel.Email,
                firstName = regModel.FirstName,
                lastName = regModel.LastName,
                phone = regModel.Phone,
                password = regModel.Password
            });

            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<RegisterResult>();
                if (result != null && result.Success)
                {
                    successMessage = "Registration successful! Redirecting to login...";
                    StateHasChanged();
                    await Task.Delay(2000);
                    NavigationManager.NavigateTo(GetLoginUrl());
                    return;
                }
            }

            var errData = await response.Content.ReadFromJsonAsync<ErrorResponse>();
            errorMessage = errData?.Error ?? "Registration failed";
        }
        catch (Exception ex)
        {
            errorMessage = $"Network error: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    public class RegisterViewModel
    {
        [Required(ErrorMessage = "First name is required")]
        public string FirstName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Last name is required")]
        public string LastName { get; set; } = string.Empty;

        [Required(ErrorMessage = "Email address is required")]
        [EmailAddress(ErrorMessage = "Please enter a valid email address")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "Mobile number is required")]
        public string Phone { get; set; } = string.Empty;

        public string? AccountNumber { get; set; }

        [Required(ErrorMessage = "Password is required")]
        [MinLength(6, ErrorMessage = "Password must be at least 6 characters")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "Confirm password is required")]
        public string ConfirmPassword { get; set; } = string.Empty;
    }

    public class RegisterResult
    {
        public bool Success { get; set; }
        public string? Token { get; set; }
    }

    public class ErrorResponse
    {
        public string? Error { get; set; }
    }
}
