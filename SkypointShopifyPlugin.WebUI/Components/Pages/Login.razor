@page "/login"
@layout LoginLayout
@inject HttpClient Http
@inject ProtectedSessionStorage SessionStorage
@inject NavigationManager NavigationManager
@using System.ComponentModel.DataAnnotations
@using System.Text.Json

<div class="split-layout-container">
    <!-- Left Feature Pane -->
    <div class="split-left-pane">
        <div class="left-pane-pill">
            <i class="fas fa-shipping-fast mr-2"></i> Customer Portal
        </div>
        <h1 class="left-pane-title">
            Ship smarter<br />
            with SkyNet Online
        </h1>
        <p class="left-pane-desc">
            Join thousands of customers sending packages locally and internationally — fast, affordable, and fully tracked.
        </p>

        <div class="left-pane-features">
            <div class="feature-item">
                <div class="feature-icon-wrapper">
                    <i class="fas fa-map-marker-alt"></i>
                </div>
                <div>
                    <div class="feature-text-title">Real-time tracking</div>
                    <div class="feature-text-desc">Know exactly where your package is at every step of the journey.</div>
                </div>
            </div>

            <div class="feature-item">
                <div class="feature-icon-wrapper">
                    <i class="fas fa-globe"></i>
                </div>
                <div>
                    <div class="feature-text-title">Local & international delivery</div>
                    <div class="feature-text-desc">Ship to destinations across South Africa and globally with ease.</div>
                </div>
            </div>

            <div class="feature-item">
                <div class="feature-icon-wrapper">
                    <i class="fas fa-wallet"></i>
                </div>
                <div>
                    <div class="feature-text-title">Prepaid & flexible payments</div>
                    <div class="feature-text-desc">No accounts or paperwork — pay online and start shipping immediately.</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Right Form Pane -->
    <div class="split-right-pane">
        <div class="form-card-wrapper">
            <div class="form-pill-badge">
                Customer
            </div>
            <h2 class="form-welcome-title">Welcome back</h2>
            <p class="form-welcome-subtitle">Sign in to your SkyNet Online customer account to manage shipments and track parcels.</p>

            <EditForm Model="@loginModel" OnValidSubmit="HandleLogin">
                <DataAnnotationsValidator />

                <div class="form-group-light">
                    <label class="form-label-light" for="username">Email Address</label>
                    <div class="input-container-light">
                        <i class="fas fa-envelope input-icon-left"></i>
                        <InputText id="username" class="form-input-light" placeholder="Email" @bind-Value="loginModel.Username" required />
                    </div>
                    <ValidationMessage For="@(() => loginModel.Username)" style="color: #ef4444; font-size: 0.8rem; margin-top: 5px;" />
                </div>

                <div class="form-group-light">
                    <label class="form-label-light" for="password">Password</label>
                    <div class="input-container-light">
                        <i class="fas fa-lock input-icon-left"></i>
                        <input type="@PasswordType" id="password" class="form-input-light" placeholder="Password" @bind="loginModel.Password" required />
                        <i class="@PasswordToggleIcon password-toggle-light" @onclick="TogglePasswordVisibility"></i>
                    </div>
                    <ValidationMessage For="@(() => loginModel.Password)" style="color: #ef4444; font-size: 0.8rem; margin-top: 5px;" />
                </div>

                @*<a href="#" class="form-link-highlight" style="font-size: 0.85rem; display: block; text-align: right; margin-top: -0.5rem; margin-bottom: 2rem;">Forgot your password?</a>*@

                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="msg error" style="display: block; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: #ef4444; padding: 10px 15px; border-radius: 6px; margin-bottom: 1.5rem; font-size: 0.9rem;">@errorMessage</div>
                }
                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div class="msg success" style="display: block; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2); color: #10b981; padding: 10px 15px; border-radius: 6px; margin-bottom: 1.5rem; font-size: 0.9rem;">@successMessage</div>
                }

                <button type="submit" class="btn-skynet-red" disabled="@isSubmitting">
                    <i class="fas fa-sign-in-alt mr-2"></i> @(isSubmitting ? "Connecting to SkyNet Online..." : "Login")
                </button>

                <a href="@GetRegisterLink()" class="btn-skynet-outline-red">
                    <i class="fas fa-user-plus mr-2"></i> Create an Account
                </a>

                <div style="text-align: center; margin-top: 2rem; font-size: 0.9rem; color: #64748b;">
                    Don't have an account? <a href="@GetRegisterLink()" class="form-link-highlight">Register here &rarr;</a>
                </div>
            </EditForm>
        </div>
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Shop { get; set; }

    private LoginViewModel loginModel = new();
    private bool isSubmitting = false;
    private bool showPassword = false;
    private string? errorMessage;
    private string? successMessage;

    private string PasswordType => showPassword ? "text" : "password";
    private string PasswordToggleIcon => showPassword ? "fas fa-eye-slash" : "fas fa-eye";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // Check if user is already logged in
                var tokenResult = await SessionStorage.GetAsync<string>("skypoint_token");
                if (tokenResult.Success && !string.IsNullOrEmpty(tokenResult.Value))
                {
                    RedirectToDashboard();
                }
            }
            catch
            {
                // Degrade gracefully during pre-rendering
            }
        }
    }

    private void TogglePasswordVisibility()
    {
        showPassword = !showPassword;
    }

    private string GetCancelUrl()
    {
        return string.IsNullOrEmpty(Shop) ? "/" : $"?shop={Uri.EscapeDataString(Shop)}";
    }

    private string GetRegisterLink()
    {
        return string.IsNullOrEmpty(Shop) ? "/register" : $"/register?shop={Uri.EscapeDataString(Shop)}";
    }

    private void LoginWithAad()
    {
        errorMessage = "Microsoft AAD authentication is currently under development. Please log in using your SkyNet Client email and password below.";
        successMessage = null;
    }

    private async Task HandleLogin()
    {
        isSubmitting = true;
        errorMessage = null;
        successMessage = null;
        StateHasChanged();

        var loginUrl = string.IsNullOrEmpty(Shop) 
            ? "api/auth/login" 
            : $"api/auth/login?shop={Uri.EscapeDataString(Shop)}";

        try
        {
            var response = await Http.PostAsJsonAsync(loginUrl, new { username = loginModel.Username, pwd = loginModel.Password });
            
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<LoginResult>();
                if (result != null && result.Success)
                {
                    await SessionStorage.SetAsync("skypoint_token", result.Token ?? "");
                    await SessionStorage.SetAsync("skypoint_user", JsonSerializer.Serialize(result.User));
                    if (!string.IsNullOrEmpty(Shop))
                    {
                        await SessionStorage.SetAsync("skypoint_shop", Shop);
                    }

                    successMessage = "Login successful! Redirecting...";
                    StateHasChanged();
                    await Task.Delay(600);
                    RedirectToDashboard();
                    return;
                }
            }

            // Error path
            var errData = await response.Content.ReadFromJsonAsync<ErrorResponse>();
            errorMessage = errData?.Error ?? "Login failed. Check your credentials.";
        }
        catch (Exception ex)
        {
            errorMessage = $"Network error: {ex.Message}";
        }
        finally
        {
            isSubmitting = false;
            StateHasChanged();
        }
    }

    private void RedirectToDashboard()
    {
        var dest = string.IsNullOrEmpty(Shop) ? "/dashboard" : $"/dashboard?shop={Uri.EscapeDataString(Shop)}";
        NavigationManager.NavigateTo(dest);
    }

    public class LoginViewModel
    {
        [Required(ErrorMessage = "Email address is required")]
        [EmailAddress(ErrorMessage = "Please enter a valid email address")]
        public string Username { get; set; } = string.Empty;

        [Required(ErrorMessage = "Password is required")]
        public string Password { get; set; } = string.Empty;
    }

    public class LoginResult
    {
        public bool Success { get; set; }
        public string? Token { get; set; }
        public object? User { get; set; }
    }

    public class ErrorResponse
    {
        public string? Error { get; set; }
    }
}
