@code {
    [SupplyParameterFromQuery]
    public string? Shop { get; set; }

    private bool isLoaded = false;
    private UserProfile? user;
    private string? token;

    // Carrier setup fields
    private bool carrierLoading = true;
    private bool carrierSuccess = false;
    private bool reinstallRequired = false;
    private bool noToken = false;
    private string? carrierMessage;
    private string? reinstallUrl;

    // Order tracking fields
    private List<SkypointOrder> orders = new();
    private SkypointOrder? selectedOrder;
    private bool isLoadingOrders = false;
    private string activeTab = "timeline";
    private bool isLoadingPudoSelection = false;
    private bool isDownloadingWaybill = false;
    private string? downloadingOrderId;

    // Pagination & Filtering
    private int currentPage = 1;
    private int pageSize = 10;
    private int totalOrders = 0;
    private int totalPages = 1;
    private string searchTerm = "";
    private string searchField = "Track No";
    private string dateRangeType = "Created Date";
    private string startDateStr = "";
    private string endDateStr = "";

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                await JSRuntime.InvokeVoidAsync("eval", @"
                    window.downloadBase64File = function(base64String, fileName, mimeType) {
                        const byteCharacters = atob(base64String.trim().replace(/\s/g, ''));
                        const byteNumbers = new Array(byteCharacters.length);
                        for (let i = 0; i < byteCharacters.length; i++) {
                            byteNumbers[i] = byteCharacters.charCodeAt(i);
                        }
                        const byteArray = new Uint8Array(byteNumbers);
                        const blob = new Blob([byteArray], {type: mimeType});
                        const blobUrl = URL.createObjectURL(blob);
                        
                        const downloadLink = document.createElement('a');
                        downloadLink.href = blobUrl;
                        downloadLink.download = fileName;
                        document.body.appendChild(downloadLink);
                        downloadLink.click();
                        document.body.removeChild(downloadLink);
                        URL.revokeObjectURL(blobUrl);
                    };
                ");

                var tokenResult = await SessionStorage.GetAsync<string>("skypoint_token");
                if (!tokenResult.Success || string.IsNullOrEmpty(tokenResult.Value))
                {
                    var redirectUrl = string.IsNullOrEmpty(Shop) ? "/login" : $"/login?shop={Uri.EscapeDataString(Shop)}";
                    NavigationManager.NavigateTo(redirectUrl);
                    return;
                }

                token = tokenResult.Value;

                var userResult = await SessionStorage.GetAsync<string>("skypoint_user");
                if (userResult.Success && !string.IsNullOrEmpty(userResult.Value))
                {
                    user = JsonSerializer.Deserialize<UserProfile>(userResult.Value, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                }

                isLoaded = true;
                StateHasChanged();

                if (!string.IsNullOrEmpty(Shop))
                {
                    await SetupCarrier();
                }

                await LoadOrders();
            }
            catch
            {
                // Graceful degradation during pre-render
            }
        }
    }

    private async Task SetupCarrier()
    {
        carrierLoading = true;
        StateHasChanged();

        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Get, $"api/shopify/setup?shop={Uri.EscapeDataString(Shop!)}");
            if (!string.IsNullOrEmpty(token))
            {
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }
            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                var data = await response.Content.ReadFromJsonAsync<CarrierSetupResponse>();
                if (data != null)
                {
                    carrierMessage = data.Message ?? data.Error;
                    
                    if (data.Success)
                    {
                        carrierSuccess = true;
                    }
                    else if (data.Status == "reinstall_required")
                    {
                        reinstallRequired = true;
                        reinstallUrl = data.InstallUrl ?? $"api/shopify?shop={Uri.EscapeDataString(Shop!)}";
                    }
                    else if (data.Status == "no_token")
                    {
                        noToken = true;
                    }
                }
            }
            else
            {
                carrierMessage = "Failed to communicate with setup endpoint.";
            }
        }
        catch (Exception ex)
        {
            carrierMessage = $"Carrier setup skipped or failed: {ex.Message}";
        }
        finally
        {
            carrierLoading = false;
            StateHasChanged();
        }
    }

    public class UserProfile
    {
        public string? Id { get; set; }
        public string? Username { get; set; }
        public string? Email { get; set; }
        public string? FirstName { get; set; }
        public string? LastName { get; set; }
        public string? Role { get; set; }
        public string? AccountNo { get; set; }
        public string? SalesCode { get; set; }
    }

    public class CarrierSetupResponse
    {
        public bool Success { get; set; }
        public string? Status { get; set; }
        public string? Message { get; set; }
        public string? Error { get; set; }
        [JsonPropertyName("install_url")]
        public string? InstallUrl { get; set; }
    }

    private string GetStatusPillStyle(string? status)
    {
        if (string.IsNullOrEmpty(status))
            return "background: rgba(234, 179, 8, 0.15); color: #eab308;"; // Yellow / Booked

        if (status.Equals("Admin POD", StringComparison.OrdinalIgnoreCase))
            return "background: rgba(52, 211, 153, 0.15); color: #34d399;"; // Green / POD

        if (status.Equals("Collection Cancelled", StringComparison.OrdinalIgnoreCase))
            return "background: rgba(248, 113, 113, 0.15); color: #f87171;"; // Red / Cancelled

        return "background: rgba(59, 130, 246, 0.15); color: #60a5fa;"; // Blue / Processing
    }

    private void ToggleSelectOrder(SkypointOrder order)
    {
        if (selectedOrder?.Id == order.Id)
        {
            selectedOrder = null;
        }
        else
        {
            selectedOrder = order;
        }
        StateHasChanged();
    }

    private async Task LoadOrders()
    {
        isLoadingOrders = true;
        StateHasChanged();

        try
        {
            DateTime? startDate = null;
            DateTime? endDate = null;

            if (DateTime.TryParse(startDateStr, out var sd))
            {
                startDate = sd;
            }
            if (DateTime.TryParse(endDateStr, out var ed))
            {
                endDate = ed;
            }

            var filter = new SkypointOrderFilter
            {
                Page = currentPage,
                Limit = pageSize,
                SearchTerm = searchTerm,
                StartDate = startDate,
                EndDate = endDate
            };

            using var request = new HttpRequestMessage(HttpMethod.Post, "api/skypoint/orders/list");
            if (!string.IsNullOrEmpty(token))
            {
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }
            request.Content = JsonContent.Create(filter);
            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                var data = await response.Content.ReadFromJsonAsync<SkypointOrderListResponse>();
                if (data != null && data.Success)
                {
                    orders = data.Orders ?? new List<SkypointOrder>();
                    if (data.Pagination != null)
                    {
                        currentPage = data.Pagination.Page;
                        pageSize = data.Pagination.Limit;
                        totalOrders = data.Pagination.Total;
                        totalPages = data.Pagination.TotalPages;
                    }
                    else
                    {
                        totalOrders = orders.Count;
                        totalPages = 1;
                    }
                }
            }
        }
        catch (Exception ex)
        {
            carrierMessage = $"Failed to load orders: {ex.Message}";
        }
        finally
        {
            isLoadingOrders = false;
            StateHasChanged();
        }
    }

    private IEnumerable<int> GetPageNumbers()
    {
        int start = Math.Max(1, currentPage - 2);
        int end = Math.Min(totalPages, start + 4);
        if (end - start < 4)
        {
            start = Math.Max(1, end - 4);
        }
        return Enumerable.Range(start, Math.Max(1, end - start + 1));
    }

    private async Task OnPageSizeChanged(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var result))
        {
            pageSize = result;
            currentPage = 1;
            await LoadOrders();
        }
    }

    private async Task GoToPage(int page)
    {
        currentPage = page;
        await LoadOrders();
    }

    private async Task PreviousPage()
    {
        if (currentPage > 1)
        {
            currentPage--;
            await LoadOrders();
        }
    }

    private async Task NextPage()
    {
        if (currentPage < totalPages)
        {
            currentPage++;
            await LoadOrders();
        }
    }

    private async Task ApplySearch()
    {
        currentPage = 1;
        await LoadOrders();
    }

    private async Task HandleSearchKeyUp(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            await ApplySearch();
        }
    }

    private async Task ResetSearch()
    {
        searchTerm = "";
        startDateStr = "";
        endDateStr = "";
        currentPage = 1;
        await LoadOrders();
    }

    private async Task ApplyFilters()
    {
        currentPage = 1;
        await LoadOrders();
    }

    private async Task SyncOrderTracking(SkypointOrder order)
    {
        isLoadingOrders = true;
        StateHasChanged();

        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Post, $"api/skypoint/orders/{order.Id}/sync");
            if (!string.IsNullOrEmpty(token))
            {
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }
            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                await LoadOrders();
                if (selectedOrder != null && selectedOrder.Id == order.Id)
                {
                    selectedOrder = orders.FirstOrDefault(o => o.Id == order.Id);
                }
            }
        }
        catch (Exception ex)
        {
            carrierMessage = $"Failed to sync status: {ex.Message}";
        }
        finally
        {
            isLoadingOrders = false;
            StateHasChanged();
        }
    }

    private async Task ProcessOrderBooking(SkypointOrder order, bool force = false)
    {
        isLoadingOrders = true;
        StateHasChanged();

        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Post, $"api/skypoint/orders/{order.Id}/process{(force ? "?force=true" : "")}");
            if (!string.IsNullOrEmpty(token))
            {
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }
            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                carrierMessage = $"Successfully created SkyNet Online booking for order #{order.OrderNumber}!";
                await LoadOrders();
                if (selectedOrder != null && selectedOrder.Id == order.Id)
                {
                    selectedOrder = orders.FirstOrDefault(o => o.Id == order.Id);
                }
            }
            else
            {
                try
                {
                    var errResult = await response.Content.ReadFromJsonAsync<SkypointOrderResponse>();
                    carrierMessage = $"Failed to book: {errResult?.Message ?? "Server error"}";
                }
                catch
                {
                    carrierMessage = "Failed to book: Server returned an error status.";
                }
            }
        }
        catch (Exception ex)
        {
            carrierMessage = $"Failed to process booking: {ex.Message}";
        }
        finally
        {
            isLoadingOrders = false;
            StateHasChanged();
        }
    }

    private async Task LaunchPudoSelection(SkypointOrder order)
    {
        isLoadingPudoSelection = true;
        StateHasChanged();

        try
        {
            var shopDomain = string.IsNullOrEmpty(Shop) ? "deeprintztestapp.myshopify.com" : Shop;
            var address = order.ShippingAddress != null 
                ? $"{order.ShippingAddress.Address1}, {order.ShippingAddress.City}, {order.ShippingAddress.Province}, {order.ShippingAddress.Zip}" 
                : "140 North Reef Road, Cape Town";
            
            var baseUri = new Uri(NavigationManager.BaseUri);
            var domain = $"{baseUri.Scheme}://{baseUri.Host}{(baseUri.IsDefaultPort ? "" : $":{baseUri.Port}")}";

            using var request = new HttpRequestMessage(HttpMethod.Get, $"api/pudo/widget-url?shop={Uri.EscapeDataString(shopDomain)}&address={Uri.EscapeDataString(address)}&domain={Uri.EscapeDataString(domain)}");
            if (!string.IsNullOrEmpty(token))
            {
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<WidgetUrlResponse>();
                if (result != null && result.Success && !string.IsNullOrEmpty(result.WidgetUrl))
                {
                    var dotNetHelper = DotNetObjectReference.Create(this);
                    await JSRuntime.InvokeVoidAsync("skypointPudo.openPudoSelector", result.Guid, result.WidgetUrl, dotNetHelper);

                    // Start background polling fallback in case window postMessage is blocked (e.g. inside iframes/popups)
                    _ = Task.Run(async () =>
                    {
                        var guid = result.Guid;
                        var shopDomain = string.IsNullOrEmpty(Shop) ? "deeprintztestapp.myshopify.com" : Shop;
                        
                        // Poll every 2.5 seconds for up to 5 minutes (120 attempts)
                        for (int i = 0; i < 120; i++)
                        {
                            await Task.Delay(2500);
                            
                            // Stop if already completed (e.g. by message listener)
                            if (!isLoadingPudoSelection) break;
                            
                            try
                            {
                                using var checkRequest = new HttpRequestMessage(HttpMethod.Get, $"api/pudo/selected/{guid}?shop={Uri.EscapeDataString(shopDomain)}");
                                if (!string.IsNullOrEmpty(token))
                                {
                                    checkRequest.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                                }
                                
                                var checkResponse = await Http.SendAsync(checkRequest);
                                if (checkResponse.IsSuccessStatusCode)
                                {
                                    var checkResult = await checkResponse.Content.ReadFromJsonAsync<SelectedPudoResponse>();
                                    if (checkResult != null && checkResult.Success && checkResult.PudoPoint != null && !string.IsNullOrEmpty(guid))
                                    {
                                        // User successfully selected a point! Trigger selection handler on the UI thread
                                        await InvokeAsync(async () => {
                                            await OnPudoSelected(guid);
                                        });
                                        break;
                                    }
                                }
                            }
                            catch (Exception)
                            {
                                // Ignore transient network/routing errors during polling
                            }
                        }
                    });
                }
                else
                {
                    carrierMessage = "Failed to generate PUDO widget URL.";
                    isLoadingPudoSelection = false;
                    StateHasChanged();
                }
            }
            else
            {
                carrierMessage = "Failed to communicate with PUDO widget URL generator.";
                isLoadingPudoSelection = false;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            carrierMessage = $"Failed to open PUDO selector: {ex.Message}";
            isLoadingPudoSelection = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task OnPudoSelected(string guid)
    {
        try
        {
            // Explicitly close the popup in case of polling or browser restrictions
            await JSRuntime.InvokeVoidAsync("skypointPudo.closePopup");

            var shopDomain = string.IsNullOrEmpty(Shop) ? "deeprintztestapp.myshopify.com" : Shop;
            using var request = new HttpRequestMessage(HttpMethod.Get, $"api/pudo/selected/{guid}?shop={Uri.EscapeDataString(shopDomain)}");

            if (!string.IsNullOrEmpty(token))
            {
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                var result = await response.Content.ReadFromJsonAsync<SelectedPudoResponse>();
                if (result != null && result.Success && result.PudoPoint != null)
                {
                    var point = result.PudoPoint;
                    if (selectedOrder != null)
                    {
                        selectedOrder.ToCounterCode = point.Code;
                        selectedOrder.ToCounterName = point.Name;
                        selectedOrder.PudoAddress1 = point.Addr1;
                        selectedOrder.PudoCity = point.City;
                        selectedOrder.PudoZip = point.Pcode;
                        selectedOrder.PudoProvider = point.Provider;

                        if (selectedOrder.ShippingAddress != null)
                        {
                            selectedOrder.ShippingAddress.Address1 = point.Addr1;
                            selectedOrder.ShippingAddress.Address2 = point.Suburb;
                            selectedOrder.ShippingAddress.City = point.City;
                            selectedOrder.ShippingAddress.Zip = point.Pcode;
                        }

                        using var updateRequest = new HttpRequestMessage(HttpMethod.Put, $"api/skypoint/orders/{selectedOrder.Id}/pudo");
                        if (!string.IsNullOrEmpty(token))
                        {
                            updateRequest.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
                        }

                        updateRequest.Content = JsonContent.Create(new UpdateOrderPudoRequest
                        {
                            ToCounterCode = point.Code,
                            ToCounterName = point.Name,
                            PudoAddress1 = point.Addr1,
                            PudoSuburb = point.Suburb,
                            PudoCity = point.City,
                            PudoZip = point.Pcode,
                            PudoProvider = point.Provider
                        });

                        var updateResponse = await Http.SendAsync(updateRequest);
                        if (updateResponse.IsSuccessStatusCode)
                        {
                            carrierMessage = $"Successfully selected PUDO point: {point.Name} ({point.Code})";
                            await LoadOrders();
                        }
                        else
                        {
                            carrierMessage = "PUDO point selected, but failed to save details to database.";
                        }
                    }
                }
                else
                {
                    carrierMessage = "Failed to load PUDO point details from server.";
                }
            }
            else
            {
                carrierMessage = "Failed to fetch selected PUDO point from API.";
            }
        }
        catch (Exception ex)
        {
            carrierMessage = $"Error processing selected PUDO point: {ex.Message}";
        }
        finally
        {
            isLoadingPudoSelection = false;
            StateHasChanged();
        }
    }

    private async Task DownloadWaybillPdf(string orderId)
    {
        if (isDownloadingWaybill) return;

        isDownloadingWaybill = true;
        downloadingOrderId = orderId;
        StateHasChanged();

        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Get, $"api/skypoint/orders/{orderId}/waybill/download");
            if (!string.IsNullOrEmpty(token))
            {
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }
            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                var data = await response.Content.ReadFromJsonAsync<WaybillDownloadResponse>();
                if (data != null && !string.IsNullOrEmpty(data.FileStream))
                {
                    var mimeType = data.ApplicationType ?? "application/pdf";
                    var fileName = data.FileName ?? $"waybill_{orderId}.pdf";
                    await JSRuntime.InvokeVoidAsync("downloadBase64File", data.FileStream, fileName, mimeType);
                    carrierMessage = "Waybill downloaded successfully.";
                }
                else
                {
                    carrierMessage = "Failed to download waybill: Response stream was empty.";
                }
            }
            else
            {
                var errBody = await response.Content.ReadAsStringAsync();
                carrierMessage = $"Failed to download waybill: {response.ReasonPhrase}. Details: {errBody}";
            }
        }
        catch (Exception ex)
        {
            carrierMessage = $"Error downloading waybill: {ex.Message}";
        }
        finally
        {
            isDownloadingWaybill = false;
            downloadingOrderId = null;
            StateHasChanged();
        }
    }

