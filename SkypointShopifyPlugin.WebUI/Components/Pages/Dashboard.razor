@page "/dashboard"
@inject HttpClient Http
@inject ProtectedSessionStorage SessionStorage
@inject NavigationManager NavigationManager

<div class="dashboard-container" style="max-width: 1100px; margin: 40px auto; padding: 0 20px; color: #ffffff;">
    @if (!isLoaded)
    {
        <div class="text-center py-5">
            <i class="fas fa-spinner fa-spin mr-2" style="font-size: 1.5rem; color: #ff1e27;"></i> Loading dashboard...
        </div>
    }
    else
    {
        <div class="dashboard-card" id="welcomeCard" style="background: rgba(15, 22, 42, 0.75); backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 16px; padding: 2.5rem; box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4); margin-bottom: 24px;">
            <h2 class="dashboard-card-title" style="font-weight: 800; font-size: 1.5rem; color: #ffffff; margin-bottom: 0.75rem;">Welcome to SkyTrack</h2>
            @if (user != null)
            {
                <p class="dashboard-card-text" style="font-size: 0.95rem; color: #94a3b8; margin-bottom: 0.5rem;">
                    <strong>Name:</strong> @user.FirstName @user.LastName
                </p>
                <p class="dashboard-card-text" style="font-size: 0.95rem; color: #94a3b8; margin-bottom: 0.5rem;">
                    <strong>Email:</strong> @(user.Email ?? user.Username)
                </p>
            }
        </div>

        <div class="info-grid" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 20px; margin-bottom: 24px;">
            <div class="info-tile" style="background: rgba(15, 22, 42, 0.75); backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 16px; padding: 1.5rem; box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3);">
                <h3 style="color: #94a3b8; font-size: 0.8rem; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600;">Account Number</h3>
                <div class="val" style="color: #ffffff; font-weight: 700; font-size: 1.25rem;">@(user?.AccountNo ?? "-")</div>
            </div>
            <div class="info-tile" style="background: rgba(15, 22, 42, 0.75); backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 16px; padding: 1.5rem; box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3);">
                <h3 style="color: #94a3b8; font-size: 0.8rem; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600;">Sales Code</h3>
                <div class="val" style="color: #ffffff; font-weight: 700; font-size: 1.25rem;">@(user?.SalesCode ?? "-")</div>
            </div>
            <div class="info-tile" style="background: rgba(15, 22, 42, 0.75); backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 16px; padding: 1.5rem; box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3);">
                <h3 style="color: #94a3b8; font-size: 0.8rem; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600;">Role</h3>
                <div class="val" style="color: #ffffff; font-weight: 700; font-size: 1.25rem;">@(user?.Role ?? "-")</div>
            </div>
            <div class="info-tile" style="background: rgba(15, 22, 42, 0.75); backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 16px; padding: 1.5rem; box-shadow: 0 15px 30px rgba(0, 0, 0, 0.3);">
                <h3 style="color: #94a3b8; font-size: 0.8rem; margin-bottom: 8px; text-transform: uppercase; letter-spacing: 0.5px; font-weight: 600;">Email</h3>
                <div class="val" style="color: #ffffff; font-weight: 700; font-size: 1.25rem;">@(user?.Email ?? "-")</div>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(Shop))
        {
            <div class="dashboard-card" style="background: rgba(15, 22, 42, 0.75); backdrop-filter: blur(16px); border: 1px solid rgba(255, 255, 255, 0.08); border-radius: 16px; padding: 2.5rem; box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4); margin-bottom: 24px;">
                <h3 class="dashboard-card-title" style="font-size: 1.25rem; font-weight: 800; color: #ffffff; margin-bottom: 0.75rem;">Skypoint Shipping — Carrier Service</h3>
                <div id="carrierStatus" class="dashboard-card-text" style="margin-top: 15px; font-size: 0.95rem; color: #94a3b8;">
                    @if (carrierLoading)
                    {
                        <span class="spinner" style="display: inline-block; width: 20px; height: 20px; border: 3px solid rgba(255, 255, 255, 0.1); border-top-color: #ff1e27; border-radius: 50%; animation: spin 0.8s linear infinite; vertical-align: middle; margin-right: 8px;"></span>
                        <span>Setting up carrier service…</span>
                    }
                    else
                    {
                        @if (carrierSuccess)
                        {
                            <span style="color:#34d399; font-weight: 600;">✓ @carrierMessage</span>
                        }
                        else if (reinstallRequired)
                        {
                            <span style="color:#f87171; font-weight: 600;">⚠ @(carrierMessage ?? "Reconnect Shopify to continue.")</span>
                            <br /><br />
                            <a class="btn-reconnect" href="@reinstallUrl" target="_top" style="display: inline-block; background: linear-gradient(135deg, #ff1e27 0%, #d30008 100%); border: none; border-radius: 8px; padding: 0.75rem 1.5rem; color: #ffffff; font-weight: 700; font-size: 0.95rem; cursor: pointer; transition: all 0.3s ease; text-decoration: none; box-shadow: 0 4px 12px rgba(255, 30, 39, 0.3);">Reconnect Shopify</a>
                        }
                        else if (noToken)
                        {
                            <span style="color:#94a3b8; font-weight: 600;">ℹ App not fully installed yet.</span>
                        }
                        else
                        {
                            <span style="color:#f87171; font-weight: 600;">⚠ @(carrierMessage ?? "Setup failed.")</span>
                        }
                    }
                </div>
            </div>
        }
    }
</div>

<style>
    @("@keyframes spin { to { transform: rotate(360deg); } }")
</style>

@code {
    [SupplyParameterFromQuery]
    public string? Shop { get; set; }

    private bool isLoaded = false;
    private UserProfile? user;
    private string? token;

    // Carrier setup fields
    private bool carrierLoading = true;
    private bool carrierSuccess = false;
    private bool reinstallRequired = false;
    private bool noToken = false;
    private string? carrierMessage;
    private string? reinstallUrl;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                var tokenResult = await SessionStorage.GetAsync<string>("skypoint_token");
                if (!tokenResult.Success || string.IsNullOrEmpty(tokenResult.Value))
                {
                    var redirectUrl = string.IsNullOrEmpty(Shop) ? "/login" : $"/login?shop={Uri.EscapeDataString(Shop)}";
                    NavigationManager.NavigateTo(redirectUrl);
                    return;
                }

                token = tokenResult.Value;

                var userResult = await SessionStorage.GetAsync<string>("skypoint_user");
                if (userResult.Success && !string.IsNullOrEmpty(userResult.Value))
                {
                    user = JsonSerializer.Deserialize<UserProfile>(userResult.Value, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                }

                isLoaded = true;
                StateHasChanged();

                if (!string.IsNullOrEmpty(Shop))
                {
                    await SetupCarrier();
                }
            }
            catch
            {
                // Graceful degradation during pre-render
            }
        }
    }

    private async Task SetupCarrier()
    {
        carrierLoading = true;
        StateHasChanged();

        try
        {
            var requestUrl = $"api/shopify/setup?shop={Uri.EscapeDataString(Shop!)}";
            
            var request = new HttpRequestMessage(HttpMethod.Get, requestUrl);
            request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);

            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                var data = await response.Content.ReadFromJsonAsync<CarrierSetupResponse>();
                if (data != null)
                {
                    carrierMessage = data.Message ?? data.Error;
                    
                    if (data.Success)
                    {
                        carrierSuccess = true;
                    }
                    else if (data.Status == "reinstall_required")
                    {
                        reinstallRequired = true;
                        reinstallUrl = data.InstallUrl ?? $"api/shopify?shop={Uri.EscapeDataString(Shop!)}";
                    }
                    else if (data.Status == "no_token")
                    {
                        noToken = true;
                    }
                }
            }
            else
            {
                carrierMessage = "Failed to communicate with setup endpoint.";
            }
        }
        catch (Exception ex)
        {
            carrierMessage = $"Carrier setup skipped or failed: {ex.Message}";
        }
        finally
        {
            carrierLoading = false;
            StateHasChanged();
        }
    }

    public class UserProfile
    {
        public string? Id { get; set; }
        public string? Username { get; set; }
        public string? Email { get; set; }
        public string? FirstName { get; set; }
        public string? LastName { get; set; }
        public string? Role { get; set; }
        public string? AccountNo { get; set; }
        public string? SalesCode { get; set; }
    }

    public class CarrierSetupResponse
    {
        public bool Success { get; set; }
        public string? Status { get; set; }
        public string? Message { get; set; }
        public string? Error { get; set; }
        [JsonPropertyName("install_url")]
        public string? InstallUrl { get; set; }
    }
}
