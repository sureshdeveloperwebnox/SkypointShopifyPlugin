@page "/setup"
@inject HttpClient Http
@inject ProtectedSessionStorage SessionStorage
@inject NavigationManager NavigationManager
@using SkypointShopifyPlugin.Core.DTOs.Configuration

<div class="dashboard-wrapper" style="background-color: #f8fafc; color: #1e293b; min-height: 100vh; padding: 3rem 4rem; font-family: 'Outfit', 'Inter', sans-serif;">
    <div style="background: white; border: 1px solid #e2e8f0; border-radius: 8px; box-shadow: 0 4px 15px rgba(0,0,0,0.02); max-width: 900px; width: 100%; margin: 0 auto; padding: 2.5rem;">
        <div style="text-align: center; margin-bottom: 2rem;">
            <h2 style="font-size: 2rem; font-weight: 800; color: #0f172a; margin-bottom: 0.5rem;">Centralized Configuration</h2>
            <p style="font-size: 1rem; color: #64748b;">Set up your Shopify and SkyNet Online API credentials and default parameters.</p>
        </div>

        @if (!isLoaded)
        {
            <div class="text-center py-4" style="color: #64748b;">
                <i class="fas fa-spinner fa-spin mr-2" style="color: #ff1e27;"></i> Loading configuration...
            </div>
        }
        else
        {
            <EditForm Model="@config" OnValidSubmit="SaveConfiguration">
                <!-- Shopify Configuration -->
                <div style="font-size: 1.1rem; font-weight: 800; border-bottom: 2px solid #ff1e27; padding-bottom: 6px; margin-bottom: 20px; color: #ff1e27; text-transform: uppercase; letter-spacing: 0.5px;">Shopify Configuration</div>
                
                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 1.5rem;">
                    <div class="form-group-light">
                        <label class="form-label-light" for="shopifyClientId">Client ID</label>
                        <div class="input-container-light">
                            <i class="fas fa-id-badge input-icon-left"></i>
                            <InputText id="shopifyClientId" class="form-input-light" placeholder="Shopify Client ID" @bind-Value="@config.Shopify.ClientId" required />
                        </div>
                    </div>
                    <div class="form-group-light">
                        <label class="form-label-light" for="shopifyClientSecret">Client Secret</label>
                        <div class="input-container-light">
                            <i class="fas fa-key input-icon-left"></i>
                            <input type="password" id="shopifyClientSecret" class="form-input-light" placeholder="Shopify Client Secret" @bind="@config.Shopify.ClientSecret" required />
                        </div>
                    </div>
                </div>

                <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; margin-bottom: 2rem;">
                    <div class="form-group-light">
                        <label class="form-label-light" for="shopifyRedirectUri">Redirect URI</label>
                        <div class="input-container-light">
                            <i class="fas fa-link input-icon-left"></i>
                            <InputText id="shopifyRedirectUri" class="form-input-light" placeholder="https://.../api/shopify/auth" @bind-Value="@config.Shopify.RedirectUri" required />
                        </div>
                    </div>
                    <div class="form-group-light">
                        <label class="form-label-light" for="shopifyWebhookSecret">Webhook Secret</label>
                        <div class="input-container-light">
                            <i class="fas fa-shield-alt input-icon-left"></i>
                            <input type="password" id="shopifyWebhookSecret" class="form-input-light" placeholder="Shopify Webhook Secret" @bind="@config.Shopify.WebhookSecret" required />
                        </div>
                    </div>
                </div>

                <!-- Parcel Dimensions -->
                <div style="font-size: 1.1rem; font-weight: 800; border-bottom: 2px solid #ff1e27; padding-bottom: 6px; margin-bottom: 20px; color: #ff1e27; text-transform: uppercase; letter-spacing: 0.5px;">Default Parcel Dimensions</div>
                
                <div style="display: grid; grid-template-columns: repeat(4, 1fr); gap: 1rem; margin-bottom: 2rem;">
                    <div class="form-group-light">
                        <label class="form-label-light" for="parcelLength">Length (cm)</label>
                        <div class="input-container-light">
                            <i class="fas fa-ruler-horizontal input-icon-left"></i>
                            <InputNumber id="parcelLength" class="form-input-light" placeholder="10.0" @bind-Value="@config.SkypointMappings.DefaultParcelLength" required />
                        </div>
                    </div>
                    <div class="form-group-light">
                        <label class="form-label-light" for="parcelBreadth">Breadth (cm)</label>
                        <div class="input-container-light">
                            <i class="fas fa-ruler-combined input-icon-left"></i>
                            <InputNumber id="parcelBreadth" class="form-input-light" placeholder="10.0" @bind-Value="@config.SkypointMappings.DefaultParcelBreadth" required />
                        </div>
                    </div>
                    <div class="form-group-light">
                        <label class="form-label-light" for="parcelHeight">Height (cm)</label>
                        <div class="input-container-light">
                            <i class="fas fa-arrows-alt-v input-icon-left"></i>
                            <InputNumber id="parcelHeight" class="form-input-light" placeholder="10.0" @bind-Value="@config.SkypointMappings.DefaultParcelHeight" required />
                        </div>
                    </div>
                    <div class="form-group-light">
                        <label class="form-label-light" for="parcelMass">Mass (kg)</label>
                        <div class="input-container-light">
                            <i class="fas fa-weight-hanging input-icon-left"></i>
                            <InputNumber id="parcelMass" class="form-input-light" placeholder="0.5" @bind-Value="@config.SkypointMappings.DefaultParcelMass" required />
                        </div>
                    </div>
                </div>

                @if (!string.IsNullOrEmpty(successMessage))
                {
                    <div class="msg success" style="display: block; background: rgba(16, 185, 129, 0.1); border: 1px solid rgba(16, 185, 129, 0.2); color: #10b981; padding: 12px 18px; border-radius: 6px; margin-bottom: 2rem;">
                        <strong>✓ Configuration Saved Successfully!</strong><br>
                        @successMessage
                    </div>
                }
                @if (!string.IsNullOrEmpty(errorMessage))
                {
                    <div class="msg error" style="display: block; background: rgba(239, 68, 68, 0.1); border: 1px solid rgba(239, 68, 68, 0.2); color: #ef4444; padding: 12px 18px; border-radius: 6px; margin-bottom: 2rem;">@errorMessage</div>
                }

                <div style="margin-top: 2rem; display: flex; gap: 1rem;">
                    <button type="submit" class="btn-skynet-red" disabled="@isSaving" style="flex: 1;">
                        <i class="fas fa-save mr-2"></i> @(isSaving ? "Saving..." : "Save Configuration")
                    </button>
                    <a href="/" class="btn-skynet-outline-red" style="flex: 1; margin: 0; text-align: center; line-height: 1.5;">
                        <i class="fas fa-times mr-2"></i> Cancel
                    </a>
                </div>
            </EditForm>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery]
    public string? Shop { get; set; }

    private AppConfiguration config = new();
    private bool isLoaded = false;
    private bool isSaving = false;
    private string? successMessage;
    private string? errorMessage;
    private string? token;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            try
            {
                // Authenticate check
                var tokenResult = await SessionStorage.GetAsync<string>("skypoint_token");
                if (!tokenResult.Success || string.IsNullOrEmpty(tokenResult.Value))
                {
                    var redirectUrl = string.IsNullOrEmpty(Shop) ? "/login" : $"/login?shop={Uri.EscapeDataString(Shop)}";
                    NavigationManager.NavigateTo(redirectUrl);
                    return;
                }

                token = tokenResult.Value;
                await LoadConfiguration();
            }
            catch
            {
                // Graceful degradation during pre-render
            }
        }
    }

    private async Task LoadConfiguration()
    {
        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Get, "api/configuration");
            if (!string.IsNullOrEmpty(token))
            {
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }
            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                config = await response.Content.ReadFromJsonAsync<AppConfiguration>() ?? new();
            }
            else
            {
                errorMessage = $"Failed to load configuration: {response.ReasonPhrase}";
            }
            isLoaded = true;
            StateHasChanged();
        }
        catch (Exception ex)
        {
            errorMessage = $"Failed to load configuration: {ex.Message}";
            isLoaded = true;
            StateHasChanged();
        }
    }

    private async Task SaveConfiguration()
    {
        isSaving = true;
        successMessage = null;
        errorMessage = null;
        StateHasChanged();

        try
        {
            using var request = new HttpRequestMessage(HttpMethod.Post, "api/configuration")
            {
                Content = JsonContent.Create(config)
            };
            if (!string.IsNullOrEmpty(token))
            {
                request.Headers.Authorization = new System.Net.Http.Headers.AuthenticationHeaderValue("Bearer", token);
            }
            var response = await Http.SendAsync(request);
            if (response.IsSuccessStatusCode)
            {
                successMessage = "Your configuration has been saved. It is now active and applied.";
            }
            else
            {
                errorMessage = "Failed to save configuration. Server returned error.";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Network error: {ex.Message}";
        }
        finally
        {
            isSaving = false;
            StateHasChanged();
        }
    }
}
