# Shopify Credentials
Shopify__ClientId=YOUR_SHOPIFY_CLIENT_ID
Shopify__ClientSecret=YOUR_SHOPIFY_CLIENT_SECRETShopify__RedirectUri=https://eboni-unprizable-discriminatingly.ngrok-free.dev/api/shopify/auth

Shopify__RedirectUri=https://your-ngrok-url.ngrok-free.dev/api/shopify/auth
Shopify__WebhookSecret=YOUR_SHOPIFY_WEBHOOK_SECRET

# Skypoint API Configuration
SkypointApi__BaseUrl=https://uat.skypoint.online
SkypointApi__LoginEndpoint=/api/service/session/customer/login
SkypointApi__RegisterEndpoint=/api/service/session/customer/register
SkypointApi__RateEndpoint=/api/service/rate/engine/quote
SkypointApi__BookingEndpoint=/api/service/booking/create
SkypointApi__TimeoutSeconds=30
SkypointApi__MaxRetryAttempts=3

# Skypoint Order Store Configuration
SkypointOrderStore__DataDirectory=data/orders

# Default Shop Domain (for testing when shop domain is not in headers)
DEFAULT_SHOP_DOMAIN=your-shop.myshopify.com

# Default Parcel Dimensions (in cm)
Skypoint__DefaultParcelLength=10.0
Skypoint__DefaultParcelBreadth=10.0
Skypoint__DefaultParcelHeight=10.0
Skypoint__DefaultParcelMass=0.5
Skypoint__DefaultParcelType=A4_Text_Book

# Postal Code Mappings (format: OriginalCode=MappedCode)
Skypoint__PostalCodeMappings__Johannesburg=2000
Skypoint__PostalCodeMappings__Pretoria=0002
Skypoint__PostalCodeMappings__CapeTown=8000
Skypoint__PostalCodeMappings__Durban=4001
Skypoint__PostalCodeMappings__Bloemfontein=9301
Skypoint__PostalCodeMappings__PortElizabeth=6001

# Suburb Mappings (format: SuburbName=MappedSuburb)
Skypoint__SuburbMappings__Germiston=Johannesburg
Skypoint__SuburbMappings__JohannesburgSouth=Johannesburg
